# LexNordic Migration Board runtime configuration.
# Copy to .env.local for local development. Do not commit real secrets.

APP_ENV=development
APP_NAME=LexNordic Migration Board
APP_PUBLIC_URL=http://127.0.0.1:5173
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Supabase: matter database, auth, storage, realtime.
SUPABASE_PROJECT_REF=cckykunswdzriungnapg
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_DATABASE_URL=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=
SUPABASE_DB_SSLMODE=require
SUPABASE_STORAGE_BUCKET=matter-documents

# Browser Auth client. These are public values only; never expose service-role keys.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_API_BASE_URL=http://127.0.0.1:8000

# Qdrant: legal source retrieval.
QDRANT_CLUSTER_ID=e246fb68-6d51-4fe0-a08b-3714a7d1b873
QDRANT_URL=https://e246fb68-6d51-4fe0-a08b-3714a7d1b873.eu-central-1-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_LEGAL_SOURCES=lexnordic_legal_sources

# Model providers.
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
LEGAL_EMBEDDING_MODEL=voyage-law-2
LEGAL_EMBEDDING_DIMENSION=1024
LEGAL_EMBEDDING_MAX_CHARS=800
LEGAL_RETRIEVAL_DEFAULT_LIMIT=8
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
AIML_CHAT_MODEL=
FEATHERLESS_CHAT_MODEL=

# Band remote agents.
BAND_API_BASE_URL=
BAND_WS_URL=
BAND_ROOM_ID=
BAND_INTAKE_AGENT_ID=
BAND_INTAKE_AGENT_API_KEY=
BAND_CONFLICT_KYC_AGENT_ID=
BAND_CONFLICT_KYC_AGENT_API_KEY=
BAND_DECISION_PARSER_AGENT_ID=
BAND_DECISION_PARSER_AGENT_API_KEY=
BAND_EVIDENCE_AGENT_ID=
BAND_EVIDENCE_AGENT_API_KEY=
BAND_LEGAL_SOURCE_AGENT_ID=
BAND_LEGAL_SOURCE_AGENT_API_KEY=
BAND_RISK_AGENT_ID=
BAND_RISK_AGENT_API_KEY=
BAND_APPEAL_PACKET_AGENT_ID=
BAND_APPEAL_PACKET_AGENT_API_KEY=
BAND_PARTNER_REVIEW_AGENT_ID=
BAND_PARTNER_REVIEW_AGENT_API_KEY=

# Local/private source paths. Do not commit extracted copyrighted text.
MIG_CORPUS_PATH=data/mig_corpus
EU_MIGRATION_LAW_BOOK_PATH=data/private/eu-migration-law-book.pdf
